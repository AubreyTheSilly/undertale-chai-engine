sin headx 0.15 2
sin headrot 0.15 2
sin heady 0.3 1

sin bodyx 0.15 1.5
sin bodyy 0.3 1.25

sin legskew 0.15 0.05

set_position head headx heady
set_property head rotation_degrees headrot
set_position body bodyx bodyy 
set_property legs skew legskew

if damaging true
set_property head visible false
set_property body visible false
set_property legs visible false
end

if damaging false
set_property head visible true
set_property body visible true
set_property legs visible true
end