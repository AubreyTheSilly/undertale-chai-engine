set_soulmode 1
set_box_size 100 70.5

var num jumper
set jumper 0

var num soulx

while jumper < 16
    wait 0.5
    increment jumper
    create_bone "bone" RIGHT DOWN 10 -3 0 0
    send_x soulx "../BattleHeart"
    math soulx soulx - 160
    if jumper == 9
        create_blaster "blaster" soulx -100 0
    end
end
send_x soulx "../BattleHeart"
math soulx soulx - 160
create_blaster "blaster" soulx -100 0
wait 2.5
set_soulmode 0
wait 1