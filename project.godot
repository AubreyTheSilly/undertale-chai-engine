; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="UNDERTALE - CHAI ENGINE"
run/main_scene="uid://dnjysem7vkqxv"
config/use_custom_user_dir=true
config/custom_user_dir_name="ChaiEngine"
config/features=PackedStringArray("4.6", "GL Compatibility")
run/max_fps=30
boot_splash/bg_color=Color(0, 0, 0, 1)
boot_splash/use_filter=false
boot_splash/image="uid://dlf6gl4db6e34"
config/icon="uid://cld6yyq8mvbqs"

[audio]

buses/default_bus_layout="uid://cvye2e3ye7l5w"

[autoload]

MouseArea="*res://Scenes/Objects/MouseArea.tscn"
Undermaker="*res://Scripts/Engine/Classes/GlobalFunc.gd"
DialogueHandler="*res://Scenes/Objects/DialogueHandler.tscn"
Battle="*res://Scripts/Engine/Classes/Battle.gd"
Items="*res://Scripts/Engine/Classes/Items.gd"
PlayerData="*res://Scripts/Engine/Classes/PlayerData.gd"
fader="*res://Scenes/Objects/fader.tscn"
Loader="*res://Scripts/Engine/Loader.gd"
BGM="*uid://cvjn3c20gea5r"
SaveMenu="*uid://cx0jyhh163q01"
ShaderLayer="*uid://b4wr16oj43w4g"
Borders="*uid://ih8bwe2ol1dt"
DiscordRPCLoader="*uid://bfihk76p5kk7e"
GlobalScriptRunner="*uid://celu5nym7wiia"

[display]

window/size/viewport_width=480
window/size/viewport_height=270
window/size/resizable=false
window/size/maximize_disabled=true
window/size/window_width_override=960
window/size/window_height_override=540
window/subwindows/embed_subwindows=false
window/stretch/mode="canvas_items"
window/stretch/scale_mode="integer"
window/per_pixel_transparency/allowed=true

[editor_plugins]

enabled=PackedStringArray("res://addons/discord-rpc-gd/plugin.cfg")

[gui]

common/snap_controls_to_pixels=false
theme/default_font_antialiasing=0
theme/default_font_hinting=0
theme/custom_font="res://Fonts/DTM-Mono.otf"

