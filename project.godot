; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="undermaker"
run/main_scene="res://Scenes/Menu.tscn"
config/features=PackedStringArray("4.3", "GL Compatibility")
run/max_fps=30
config/icon="res://icon.svg"

[autoload]

MouseArea="*res://Scenes/Objects/MouseArea.tscn"
Undermaker="*res://Scripts/Classes/GlobalFunc.gd"
DialogueHandler="*res://Scenes/Objects/DialogueHandler.tscn"
Battle="*res://Scripts/Classes/Battle.gd"

[display]

window/size/viewport_width=320
window/size/viewport_height=240
window/size/mode=3
window/size/resizable=false
window/size/window_width_override=640
window/size/window_height_override=480
window/subwindows/embed_subwindows=false
window/stretch/mode="canvas_items"

[gui]

theme/custom_font="res://Fonts/DTM-Mono.otf"

